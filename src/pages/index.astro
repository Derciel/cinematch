          <div class="split-name-tag player-b" id="split-tag-b">Ela</div>
          <div class="deck-container" id="cards-deck-b">
            <!-- Loaded dynamically -->
          </div>
          <div class="controls-panel">
            <button class="btn-action btn-dislike" id="action-split-dislike-b">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg>
            </button>
            <button class="btn-action btn-like" id="action-split-like-b">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg>
            </button>
          </div>
          <div class="keyboard-hint">
            <span>Dislike: <kbd class="keyboard-key">O</kbd></span>
            <span>Like: <kbd class="keyboard-key">P</kbd></span>
          </div>
        </div>
        
      </div>
    </section>

    <!-- 4. MATCH HISTORY & DECIDE FOR US (SPIN THE WHEEL) -->
    <section id="history-screen" class="screen">
      <div class="history-layout">
        
        <!-- Matches List -->
        <div class="matches-list-container">
          <h2 class="section-title">Nossos Matches</h2>
          <p class="section-subtitle">Filmes que ambos curtiram e aprovaram.</p>
          
          <div class="matches-grid" id="matches-display-grid">
            <!-- List will render here -->
            <div class="empty-matches">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/>
                <path d="M8 12h8M12 8v8"/>
              </svg>
              <h3>Nenhum match ainda</h3>
              <p>Comecem a jogar para encontrar filmes em comum!</p>
            </div>
          </div>
        </div>
        
        <!-- Spin the Wheel sidebar (to choose randomly between matches) -->
        <div class="decide-sidebar glass" id="roulette-section" style="display: none;">
          <h3 class="decide-title">Indecisos?</h3>
          <p class="decide-desc">Se vocês tiveram muitos matches e não conseguem decidir qual assistir hoje, deixe o CineMatch girar a roleta!</p>
          
          <div class="wheel-container">
            <div class="wheel-pointer"></div>
            <div class="wheel-center"></div>
            <div class="wheel-outer" id="spinning-wheel">
              <canvas class="wheel-canvas" id="wheel-canvas" width="220" height="220"></canvas>
            </div>
            
            <div class="spin-result-popup" id="wheel-result-popup">Filme Sorteado!</div>
          </div>
          
          <button class="btn-spin" id="spin-wheel-btn">Sortear Filme</button>
        </div>
        
      </div>
    </section>

    <!-- 5. DIARY / MEMORIES SCREEN -->
    <section id="diary-screen" class="screen">
      <div class="diary-container glass">
        <h2 class="diary-title">Nossas Memórias ❤️</h2>
        <p class="diary-subtitle">Nossa linha do tempo dos encontros e filmes que já assistimos juntos.</p>
        
        <div id="diary-timeline" class="diary-timeline">
          <!-- Dinamicamente preenchido -->
          <div class="diary-empty-state">
            <p>Vocês ainda não registraram memórias. Registrem um match na aba de Matches! 📝</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 6. IDEAS & CHALLENGES SCREEN -->
    <section id="ideas-screen" class="screen">
      <h2 class="section-title">Ideias de Encontros de Cinema</h2>
      <p class="section-subtitle">Combine os filmes com lanches, desafios e decorações temáticas para tornar a noite inesquecível!</p>
      
      <div class="ideas-grid">
        
        <!-- Card 1 -->
        <div class="idea-card glass">
          <div class="idea-header">
            <div class="idea-icon-wrapper">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 22h20L12 2z"/>
              </svg>
            </div>
            <div>
              <h3 class="idea-title">Noite Interestelar</h3>
              <p class="idea-category" style="font-size: 0.8rem; color: var(--secondary); font-weight:700;">FICÇÃO CIENTÍFICA</p>
            </div>
            <span class="idea-badge">Imersivo</span>
          </div>
          <p class="idea-description">Crie um ambiente cósmico na sala para curtir o melhor da ficção científica e viagem espacial.</p>
          <ul class="idea-details-list">
            <li class="idea-detail-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span><strong>Decoração:</strong> Luzes apagadas, pisca-pisca simulando estrelas ou luz LED azul/roxa.</span>
            </li>
            <li class="idea-detail-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span><strong>Comida:</strong> Pipoca gourmet com queijo provolone ralado (parecendo pó lunar) e refrigerante ou drink de curaçau blue.</span>
            </li>
            <li class="idea-detail-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span><strong>Desafio:</strong> De quem é a teoria do filme? Tentem explicar o paradoxo do filme no final em menos de 2 minutos.</span>
            </li>
          </ul>
          <div class="idea-footer">
            <span class="idea-difficulty">Fácil • 15 min prep</span>
            <button class="btn-idea-action" onclick="alert('Selecione Ficção Científica na aba Jogar e comece sua maratona de exploração cósmica!')">Escolher este gênero →</button>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="idea-card glass">
          <div class="idea-header">
            <div class="idea-icon-wrapper pink">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M9 17v-5h6v5M9 7h6"/>
              </svg>
            </div>
            <div>
              <h3 class="idea-title">Terror no Escuro</h3>
              <p class="idea-category" style="font-size: 0.8rem; color: var(--primary); font-weight:700;">TERROR / SUSPENSE</p>
            </div>
            <span class="idea-badge pink">Arrepiante</span>
          </div>
          <p class="idea-description">Para casais que gostam de ficar agarrados de susto. Apague tudo e prepare-se.</p>
          <ul class="idea-details-list">
            <li class="idea-detail-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span><strong>Decoração:</strong> Escuridão absoluta. Use uma vela vermelha de decoração para dar um ar místico.</span>
            </li>
            <li class="idea-detail-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span><strong>Comida:</strong> Nachos com molho 'sangrento' (ketchup picante ou geleia de pimenta vermelha sobre cream cheese).</span>
            </li>
            <li class="idea-detail-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span><strong>Desafio de Casal:</strong> A cada susto (jump scare) ou grito no filme, quem se assustar primeiro deve fazer uma massagem de 5 minutos no outro após o término.</span>
            </li>
          </ul>
          <div class="idea-footer">
            <span class="idea-difficulty">Média • 5 min prep</span>
            <button class="btn-idea-action" onclick="alert('Ligue o Terror e abrace forte o seu parceiro na próxima jogada!')">Escolher este gênero →</button>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="idea-card glass">
          <div class="idea-header">
            <div class="idea-icon-wrapper">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
              </svg>
            </div>
            <div>
              <h3 class="idea-title">Ação e Adrenalina</h3>
              <p class="idea-category" style="font-size: 0.8rem; color: var(--secondary); font-weight:700;">AÇÃO E AVENTURA</p>
            </div>
            <span class="idea-badge">Dinâmico</span>
          </div>
          <p class="idea-description">Transforme a noite em uma montanha-russa de emoções com som alto e lanches práticos.</p>
          <ul class="idea-details-list">
            <li class="idea-detail-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span><strong>Decoração:</strong> Som estéreo ou fone de ouvido compartilhado se estiver tarde. Tela o mais perto possível.</span>
            </li>
            <li class="idea-detail-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span><strong>Comida:</strong> Hambúrguer caseiro com fritas rústicas e muito cheddar (fácil de comer na mão).</span>
            </li>
            <li class="idea-detail-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span><strong>Desafio:</strong> Façam apostas no início de quem será o sobrevivente final ou quem dará o golpe final. Quem acertar ganha o direito de escolher o próximo filme sem precisar de votação!</span>
            </li>
          </ul>
          <div class="idea-footer">
            <span class="idea-difficulty">Elaborada • 30 min prep</span>
            <button class="btn-idea-action" onclick="alert('Selecione Ação ou Aventura para acelerar os batimentos cardíacos do casal!')">Escolher este gênero →</button>
          </div>
        </div>

      </div>
    </section>

    <!-- 7. WINES & PAIRING SCREEN -->
    <section id="wines-screen" class="screen">
      <h2 class="section-title">Adega CineMatch & Harmonização</h2>
      <p class="section-subtitle">A noite de cinema merece um brinde especial. Descubra a melhor combinação para o prato de hoje!</p>

      <!-- Painel Interativo de Escolha Rápida -->
      <div class="wine-interactive-selector glass" style="margin-bottom: 3rem; padding: 2.25rem 2rem; text-align: center; border: 1px solid rgba(212, 175, 55, 0.15); background: linear-gradient(135deg, rgba(114, 47, 55, 0.08), rgba(25, 30, 45, 0.1));">
        <h3 style="font-family: var(--font-serif); font-size: 1.65rem; margin-bottom: 0.5rem; color: #fff;">O que vamos comer hoje?</h3>
        <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 1.75rem;">Selecione o lanche do filme e recomendaremos o vinho perfeito!</p>
        
        <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2rem;" id="food-select-buttons">
          <button type="button" class="btn-secondary active" data-food="popcorn" style="padding: 0.5rem 1rem; font-size: 0.85rem;">🍿 Pipoca & Snacks</button>
          <button type="button" class="btn-secondary" data-food="pizza" style="padding: 0.5rem 1rem; font-size: 0.85rem;">🍕 Pizza</button>
          <button type="button" class="btn-secondary" data-food="burger" style="padding: 0.5rem 1rem; font-size: 0.85rem;">🍔 Hambúrguer</button>
          <button type="button" class="btn-secondary" data-food="sushi" style="padding: 0.5rem 1rem; font-size: 0.85rem;">🍣 Sushi</button>
          <button type="button" class="btn-secondary" data-food="pasta" style="padding: 0.5rem 1rem; font-size: 0.85rem;">🍝 Massa / Fondue</button>
          <button type="button" class="btn-secondary" data-food="chocolate" style="padding: 0.5rem 1rem; font-size: 0.85rem;">🍫 Chocolate</button>
        </div>
        
        <div class="wine-result-card glass" id="wine-result-card" style="display: flex; flex-direction: column; align-items: center; max-width: 500px; margin: 0 auto; padding: 2rem; border-radius: 18px; border: 1.5px solid rgba(212, 175, 55, 0.2); background: rgba(8, 11, 17, 0.55);">
          <!-- Carregado via Javascript -->
        </div>
      </div>

      <!-- Grid com todas as harmonizações detalhadas -->
      <h3 class="section-title" style="font-size: 1.5rem; margin-top: 3rem; margin-bottom: 1rem; font-family: var(--font-serif); text-align: center;">Guia Completo de Harmonização</h3>
      <div class="ideas-grid" style="margin-bottom: 2rem;">
        
        <!-- Card 1 -->
        <div class="idea-card glass" style="border: 1px dashed rgba(212, 175, 55, 0.15);">
          <div class="idea-header">
            <div class="idea-icon-wrapper" style="background: rgba(212, 175, 55, 0.1); color: #D4AF37; border-color: rgba(212, 175, 55, 0.2);">
              🍿
            </div>
            <div>
              <h3 class="idea-title">Pipoca & Salgadinhos</h3>
              <p class="idea-category" style="font-size: 0.8rem; color: #D4AF37; font-weight:700;">ESPUMANTE BRUT / CHARDONNAY</p>
            </div>
            <span class="idea-badge" style="background: rgba(212, 175, 55, 0.1); color: #D4AF37;">Branco / Espumante</span>
          </div>
          <p class="idea-description">A pipoca salgada com manteiga ou nachos são acompanhamentos clássicos de cinema que ganham sofisticação.</p>
          <ul class="idea-details-list">
            <li class="idea-detail-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span><strong>Por que harmoniza:</strong> A acidez do Espumante limpa o sal e a gordura da pipoca. As notas amanteigadas do Chardonnay complementam o sabor da manteiga.</span>
            </li>
            <li class="idea-detail-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span><strong>Temperatura:</strong> Servir bem resfriado, entre 6°C e 8°C para o Espumante, e 10°C para o Chardonnay.</span>
            </li>
          </ul>
        </div>

        <!-- Card 2 -->
        <div class="idea-card glass" style="border: 1px dashed rgba(114, 47, 55, 0.15);">
          <div class="idea-header">
            <div class="idea-icon-wrapper" style="background: rgba(114, 47, 55, 0.1); color: #722F37; border-color: rgba(114, 47, 55, 0.2);">
              🍕
            </div>
            <div>
              <h3 class="idea-title">Pizzas Clássicas</h3>
              <p class="idea-category" style="font-size: 0.8rem; color: #f43f5e; font-weight:700;">CHIANTI / MERLOT</p>
            </div>
            <span class="idea-badge pink" style="background: rgba(114, 47, 55, 0.1); color: #f43f5e;">Tinto Médio</span>
          </div>
          <p class="idea-description">Seja Margherita, Calabresa ou Pepperoni, as pizzas combinam idealmente com vinhos tintos italianos e frutados.</p>
          <ul class="idea-details-list">
            <li class="idea-detail-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span><strong>Por que harmoniza:</strong> A uva Sangiovese do Chianti tem acidez alta que equilibra o molho de tomate e corta a cremosidade do queijo derretido.</span>
            </li>
            <li class="idea-detail-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span><strong>Temperatura:</strong> Servir fresco, por volta de 16°C para desfrutar da riqueza de frutas.</span>
            </li>
          </ul>
        </div>

        <!-- Card 3 -->
        <div class="idea-card glass" style="border: 1px dashed rgba(114, 47, 55, 0.15);">
          <div class="idea-header">
            <div class="idea-icon-wrapper" style="background: rgba(114, 47, 55, 0.1); color: #722F37; border-color: rgba(114, 47, 55, 0.2);">
              🍔
            </div>
            <div>
              <h3 class="idea-title">Hambúrguer & Batata Frita</h3>
              <p class="idea-category" style="font-size: 0.8rem; color: #8b5cf6; font-weight:700;">MALBEC / CABERNET SAUVIGNON</p>
            </div>
            <span class="idea-badge" style="background: rgba(114, 47, 55, 0.1); color: #8b5cf6;">Tinto Encorpado</span>
          </div>
          <p class="idea-description">Para jantares informais e suculentos, vinhos robustos estruturam e casam com a força da carne bovina.</p>
          <ul class="idea-details-list">
            <li class="idea-detail-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span><strong>Por que harmoniza:</strong> Os taninos potentes do Malbec 'limpam' a boca da gordura da carne e do queijo cheddar, realçando a suculência.</span>
            </li>
            <li class="idea-detail-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span><strong>Temperatura:</strong> Ideal em torno de 17°C ou 18°C. Abra a garrafa alguns minutos antes de comer.</span>
            </li>
          </ul>
        </div>

      </div>
    </section>

  </main>

  <!-- 8. FULLSCREEN MATCH CELEBRATION OVERLAY -->
  <section class="match-overlay" id="match-celebration-screen">
    <canvas id="confetti-canvas" style="position: absolute; top:0; left:0; width:100%; height:100%; pointer-events: none; z-index: 2;"></canvas>
    
    <div class="match-box" style="z-index: 5;">
      <h1 class="match-banner">É um Match!</h1>
      <p class="match-sub" id="match-congrats-names">Dercio e Parceira deram like no mesmo filme!</p>
      
      <div class="match-card-display">
        <div class="match-poster-wrapper">
          <div class="match-hearts">❤️</div>
          <img src="" alt="Poster do Filme Match" id="match-movie-poster">
        </div>
        
        <div class="match-details-container">
          <h2 class="match-movie-title" id="match-movie-title">Interestelar</h2>
          <div class="match-movie-info">
            <span id="match-movie-year">2014</span> • 
            <span id="match-movie-duration">2h 49m</span> • 
            <span id="match-movie-rating">⭐ 8.7</span>
          </div>
          <p class="match-movie-synopsis" id="match-movie-synopsis">
            Uma equipe de exploradores viaja através de um buraco de minhoca no espaço em uma tentativa de garantir a sobrevivência da humanidade.
          </p>
          
          <div class="movie-platforms-row" style="justify-content: center; margin-bottom: 2rem;">
            <span class="movie-platforms-title">Disponível em:</span>
            <div id="match-movie-platforms" style="display: flex; gap: 0.5rem;">
              <span class="platform-tag">Max</span>
              <span class="platform-tag">Prime Video</span>
            </div>
          </div>
        </div>
      </div>
      
      <div class="match-actions">
        <button class="btn-secondary" id="match-keep-swiping-btn">Continuar Jogando</button>
        <button class="btn-cta" id="match-watch-now-btn" style="width: auto; margin-top:0;">Assistir Agora</button>
      </div>
    </div>
  </section>

  <!-- Modal de Registro de Memória (Diary) -->
  <div id="diary-modal" class="modal-overlay">
    <div class="modal-content glass">
      <h3 class="modal-title">Registrar Encontro 📝</h3>
      <p id="diary-modal-movie-title" class="modal-subtitle">Filme: Interestelar</p>
      
      <form id="diary-form" onsubmit="event.preventDefault();">
        <input type="hidden" id="diary-movie-id">
        <div class="form-group">
          <label class="form-label" style="font-size: 0.85rem; margin-bottom: 0.35rem; display:block;">Data do Encontro:</label>
          <input type="date" id="diary-date" style="width:100%; padding:0.75rem; border-radius:12px; border:1px solid var(--border-color); background:rgba(255,255,255,0.03); color:#fff; font-family:inherit; outline:none; box-sizing:border-box;" required>
        </div>
        <div class="form-group" style="margin-top: 1rem;">
          <label class="form-label" style="font-size: 0.85rem; margin-bottom: 0.25rem; display:block;">Avaliação do Casal (Corações):</label>
          <div class="heart-rating" id="heart-rating-container">
            <span class="heart-star selected" data-rating="1">❤️</span>
            <span class="heart-star selected" data-rating="2">❤️</span>
            <span class="heart-star selected" data-rating="3">❤️</span>
            <span class="heart-star selected" data-rating="4">❤️</span>
            <span class="heart-star selected" data-rating="5">❤️</span>
          </div>
          <input type="hidden" id="diary-rating-value" value="5">
        </div>
        <div class="form-group" style="margin-top: 1rem;">
          <label class="form-label" style="font-size: 0.85rem; margin-bottom: 0.35rem; display:block;">Nossas Notas / Recordações do Dia:</label>
          <textarea id="diary-notes" placeholder="Ex: Pedimos pizza e rimos muito com o robô TARS..." required></textarea>
        </div>
        
        <div class="modal-actions">
          <button type="button" class="btn-secondary" id="btn-close-diary-modal">Cancelar</button>
          <button type="submit" class="btn-cta" id="btn-save-diary" style="margin-top:0;">Salvar Memória ❤️</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Footer -->
  <footer>
    <p>CineMatch © 2026. Feito com amor para casais cinéfilos. ❤️</p>
  </footer>
</Layout>

<!-- Carregar a base de dados em tempo real -->
<script is:inline define:vars={{ moviesList }}>
  window.MOVIE_DATABASE = moviesList;
</script>

<!-- Scripts principais compilados pelo Astro -->
<script>
  import "../scripts/app.js";
</script>
