import Layout from '../layouts/Layout.astro';
import { MOVIE_DATABASE } from '../data/movies.js';

// Função para buscar providers reais do TMDB (JustWatch) para todos os filmes
async function fetchRealStreamingProviders() {
  const tmdbApiKey = import.meta.env.TMDB_API_KEY || process.env.TMDB_API_KEY;
  if (!tmdbApiKey) {
    console.log("Nenhuma chave TMDB_API_KEY encontrada. Usando plataformas locais de fallback.");
    return MOVIE_DATABASE;
  }

  console.log("TMDB_API_KEY encontrada! Carregando plataformas em tempo real do TMDb...");
  const updatedMovies = [];

  for (const movie of MOVIE_DATABASE) {
    try {
      // 1. Buscar o ID do filme pelo título e ano
      const searchUrl = `https://api.themoviedb.org/3/search/movie?api_key=${tmdbApiKey}&query=${encodeURIComponent(movie.title)}&year=${movie.year}&language=pt-BR`;
      const searchRes = await fetch(searchUrl);
      const searchData = await searchRes.json();
      
      if (searchData.results && searchData.results.length > 0) {
        const tmdbId = searchData.results[0].id;
        
        // 2. Buscar os watch providers (JustWatch) para o Brasil (BR)
        const providersUrl = `https://api.themoviedb.org/3/movie/${tmdbId}/watch/providers?api_key=${tmdbApiKey}`;
        const providersRes = await fetch(providersUrl);
        const providersData = await providersRes.json();
        
        const brProviders = providersData.results?.BR;
        const platforms = [];
        
        if (brProviders) {
          // Flatrate (streaming por assinatura)
          if (brProviders.flatrate) {
            brProviders.flatrate.forEach(p => {
              const name = p.provider_name.toLowerCase();
              if (name.includes("netflix") && !platforms.includes("Netflix")) {
                platforms.push("Netflix");
              } else if ((name.includes("max") || name.includes("hbo")) && !platforms.includes("Max")) {
                platforms.push("Max");
              } else if ((name.includes("prime") || name.includes("amazon")) && !platforms.includes("Prime Video")) {
                platforms.push("Prime Video");
              } else if (name.includes("disney") && !platforms.includes("Disney+")) {
                platforms.push("Disney+");
              } else if (name.includes("apple") && !platforms.includes("Apple TV+")) {
                platforms.push("Apple TV+");
              } else if (name.includes("globoplay") && !platforms.includes("Globoplay")) {
                platforms.push("Globoplay");
              }
            });
          }
        }
        
        // Se não encontrar nenhuma plataforma de streaming padrão, marca como On-Demand
        if (platforms.length === 0) {
          platforms.push("On-Demand");
        }
        
        updatedMovies.push({
          ...movie,
          platforms: platforms
        });
      } else {
        updatedMovies.push(movie);
      }
    } catch (err) {
      console.error(`Erro ao buscar providers para ${movie.title}:`, err);
      updatedMovies.push(movie);
    }
  }
  return updatedMovies;
}

const moviesList = await fetchRealStreamingProviders();
