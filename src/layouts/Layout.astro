---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = "CineMatch - Escolha o Filme Ideal Para o Casal" } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
